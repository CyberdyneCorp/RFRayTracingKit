{
  "name": "rftracekit",
  "version": "0.1.0",
  "description": "Modern C++ ray tracing and RF propagation library (CPU reference)",
  "dependencies": [
    "eigen3",
    "assimp",
    "nlohmann-json"
  ],
  "features": {
    "tests": {
      "description": "Build the test suite",
      "dependencies": ["gtest"]
    },
    "geo": {
      "description": "GeoTIFF/DEM import + GeoTIFF heatmap export (RFTRACE_ENABLE_GDAL)",
      "dependencies": ["gdal"]
    },
    "parquet": {
      "description": "Parquet receiver-table export (RFTRACE_ENABLE_PARQUET)",
      "dependencies": [{"name": "arrow", "features": ["parquet"]}]
    },
    "embree": {
      "description": "Optional Embree CPU ray-tracing backend (RFTRACE_ENABLE_EMBREE)",
      "dependencies": ["embree"]
    }
  }
}

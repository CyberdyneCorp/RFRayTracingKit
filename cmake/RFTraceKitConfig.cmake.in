@PACKAGE_INIT@

# The installed RFTraceKit exports a static core (and optionally the C ABI static
# library). A static library propagates its link dependencies to consumers, so the
# config re-resolves the same CONFIG-mode packages the build used. Eigen3 is a
# PUBLIC dependency (its types appear in the public headers); assimp and
# nlohmann/json are private but must still be discoverable to link the static core.
include(CMakeFindDependencyMacro)
find_dependency(Eigen3 CONFIG)
find_dependency(assimp CONFIG)
find_dependency(nlohmann_json CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/RFTraceKitTargets.cmake")

check_required_components(RFTraceKit)
